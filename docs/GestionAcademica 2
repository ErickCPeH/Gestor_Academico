openapi: 3.0.0
info:
  title: Gestión Academica
  version: 1.0.0
  description: API para gestionar estudiantes, cursos y profesores en la universidad del valle de México.
contact: 
  name: Erick Pérez, Francisco Maldonado, Jorge Vargas, Paola Gonzalez
servers: 
  - url: http://localhost:3000
    description: Servidor local de desarrollo 

paths: 
  /estudiantes: 
    get: 
      summary: Obtener lista de estudiantes
      description: Devuelve una lista de todos los estudiantes registrados en la universidad.
      responses: 
        '200': 
          description: Lista de estudiantes obtenida exitosamente
          content: 
            application/json: 
              schema: 
                type: array
                items: 
                  $ref: '#/components/schemas/Estudiante'
        '400': 
          description: Solicitud incorrecta
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 400
                message: Solicitud incorrecta
                details: Parámetros de consulta no válidos.
        '401': 
          description: No autorizado
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 401
                message: No autorizado
                details: Falta el token de autenticación Bearer o ha expirado.
        '403': 
          description: Prohibido
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 403
                message: Prohibido
                details: No tienes los permisos necesarios para ver el listado de estudiantes.
        '404': 
          description: Recurso no encontrado
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 404
                message: Recurso no encontrado
                details: No se encontraron registros.
        '500': 
          description: Error interno del servidor
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 500
                message: Error interno del servidor
                details: Ocurrió un problema de conexión con la base de datos de alumnos.
        '503': 
          description: Servicio no disponible
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 503
                message: Servicio no disponible
                details: El sistema de gestión escolar está en mantenimiento.
    post:
      summary: Crear un nuevo estudiante
      description: Agrega un nuevo estudiante a la base de datos.
      requestBody: 
        required: true
        content: 
          application/json: 
            schema: 
              $ref: '#/components/schemas/Estudiante'
      responses: 
        '201': 
          description: Estudiante creado exitosamente
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/Estudiante'
        '400': 
          description: Solicitud incorrecta
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 400
                message: Solicitud incorrecta
                details: El campo 'nombre' y 'matricula' son obligatorios.
        '401': 
          description: No autorizado
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 401
                message: No autorizado
                details: Falta el token de autenticación Bearer.
        '403': 
          description: Prohibido
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 403
                message: Prohibido
                details: Tu rol no permite la creación de nuevos estudiantes.
        '500': 
          description: Error interno del servidor
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 500
                message: Error interno del servidor
                details: Error al intentar guardar el registro en la base de datos.
        '503': 
          description: Servicio no disponible
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 503
                message: Servicio no disponible
                details: El servicio de alta de alumnos está temporalmente deshabilitado.

  /estudiantes/{id}:
    get:
      summary: Obtener un estudiante por ID
      description: Devuelve los detalles de un estudiante específico utilizando su ID.
      parameters: 
        - name: id
          in: path
          required: true
          schema: 
            type: integer
      responses: 
        '200': 
          description: Estudiante obtenido exitosamente
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/Estudiante'
        '400': 
          description: Solicitud incorrecta
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 400
                message: Solicitud incorrecta
                details: El formato del ID proporcionado no es válido.
        '401': 
          description: No autorizado
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 401
                message: No autorizado
                details: Token inválido.
        '403': 
          description: Prohibido
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 403
                message: Prohibido
                details: Acceso denegado a la información de este estudiante.
        '404': 
          description: Estudiante no encontrado
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 404
                message: Estudiante no encontrado
                details: No existe un estudiante registrado con el ID proporcionado.
        '500': 
          description: Error interno del servidor
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 500
                message: Error interno del servidor
                details: Ocurrió un error inesperado al procesar la solicitud.
        '503': 
          description: Servicio no disponible
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 503
                message: Servicio no disponible
                details: Servicio en mantenimiento.
    put:
      summary: Actualizar un estudiante por ID
      description: Actualiza los detalles de un estudiante específico utilizando su ID.
      parameters: 
        - name: id
          in: path
          required: true
          schema: 
            type: integer
      requestBody: 
        required: true
        content: 
          application/json: 
            schema: 
              $ref: '#/components/schemas/Estudiante'
      responses:
        '200': 
          description: Estudiante actualizado exitosamente
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/Estudiante'
        '400': 
          description: Solicitud incorrecta
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 400
                message: Solicitud incorrecta
                details: Los datos proporcionados para la actualización son inválidos.
        '401': 
          description: No autorizado
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 401
                message: No autorizado
                details: Token inválido.
        '403': 
          description: Prohibido
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 403
                message: Prohibido
                details: No tienes permiso para editar registros.
        '404': 
          description: Estudiante no encontrado
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 404
                message: Estudiante no encontrado
                details: El estudiante que intentas actualizar no existe.
        '500': 
          description: Error interno del servidor
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 500
                message: Error interno del servidor
                details: Fallo al intentar aplicar los cambios en la base de datos.
        '503': 
          description: Servicio no disponible
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 503
                message: Servicio no disponible
                details: Servicio en mantenimiento.
    delete:
      summary: Eliminar un estudiante por ID
      description: Elimina un estudiante específico utilizando su ID.
      parameters: 
        - name: id
          in: path
          required: true
          schema: 
            type: integer
      responses:
        '204': 
          description: Estudiante eliminado exitosamente
        '400': 
          description: Solicitud incorrecta
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 400
                message: Solicitud incorrecta
                details: El formato del ID proporcionado no es válido.
        '401': 
          description: No autorizado
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 401
                message: No autorizado
                details: Token inválido.
        '403': 
          description: Prohibido
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 403
                message: Prohibido
                details: No tienes los privilegios de administrador para eliminar registros.
        '404': 
          description: Estudiante no encontrado
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 404
                message: Estudiante no encontrado
                details: El estudiante que intentas eliminar no existe.
        '500': 
          description: Error interno del servidor
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 500
                message: Error interno del servidor
                details: Ocurrió un error al intentar procesar la baja.
        '503': 
          description: Servicio no disponible
          content: 
            application/json: 
              schema: 
                $ref: '#/components/schemas/APIError'
              example:
                code: 503
                message: Servicio no disponible
                details: Servicio en mantenimiento.

security: 
  - bearerAuth: []

components:
  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT

  schemas:
    Estudiante:
      type: object
      properties:
        matricula:
          type: string
          example: "10214559"
        nombre:
          type: string
          example: "AGUILAR HERNANDEZ IAN"
        asignatura:
          type: string
          example: "Sistemas Operativos"
        ciclo:
          type: string
          example: "C1-2026"
        evaluacion_continua:
          type: object
          properties:
            teoria_10:
              type: number
              example: 8.86
            laboratorio_40:
              type: number
              example: 8.33
            blackboard_50:
              type: number
              example: 7.85
        asistencias:
          type: object
          properties:
            faltas_totales:
              type: integer
              example: 0
            limite_permitido:
              type: integer
              example: 7
        promedio_parcial:
          type: number
          example: 8.30
    APIError:
      type: object
      properties:
        code:
          type: integer
          example: 400
        message:
          type: string
          example: Solicitud incorrecta
        details:
          type: string
          example: Ocurrió un error al procesar tu solicitud.